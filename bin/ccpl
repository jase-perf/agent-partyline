#!/usr/bin/env bash
#
# ccpl — Launch Claude Code with the party-line channel
#
# Usage:
#   ccpl              Continue most recent session (or start new)
#   ccpl research     Resume session named "research" (opens picker), or start new with that name
#   ccpl --new NAME   Force a new session with the given name (skip resume)
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

force_new=false
name=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --new)
            force_new=true
            name="${2:-}"
            shift 2
            ;;
        *)
            name="$1"
            shift
            ;;
    esac
done

base_args=(
    --dangerously-skip-permissions
    --mcp-config "$SCRIPT_DIR/.mcp.json"
    --dangerously-load-development-channels server:party-line
)

if [ -z "$name" ]; then
    # No name: continue most recent session in this directory
    exec claude "${base_args[@]}" --continue
fi

if [ "$force_new" = true ]; then
    echo "Starting new session '$name'"
    exec claude "${base_args[@]}" --name "$name"
fi

# Try to resume a session matching this name; falls back to picker
echo "Looking for session '$name'..."
exec claude "${base_args[@]}" --name "$name" --resume "$name"
